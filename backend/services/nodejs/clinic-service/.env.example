# Clinic Service
CLINIC_SERVICE_PORT=4003

# MongoDB Atlas URI (recommended)
# Format:
# mongodb+srv://<username>:<password>@<cluster-name>.mongodb.net/companion_ai?retryWrites=true&w=majority&appName=<app-name>
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-name>.mongodb.net/companion_ai?retryWrites=true&w=majority
