# ─────────────────────────────────────────────
# COMPANION DISEASE RISK AI — Environment Config
# Copy this file to .env and fill in real values
# ─────────────────────────────────────────────

# ── General ──────────────────────────────────
NODE_ENV=development
PORT=3000

# ── GCP / Firebase ───────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-southeast1
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=your-app-id

# ── MongoDB Atlas ─────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/companion-ai
MONGODB_DB_NAME=companion_ai

# ── Node.js Services ─────────────────────────
API_GATEWAY_PORT=4000
AUTH_SERVICE_PORT=4001
PET_SERVICE_PORT=4002
CLINIC_SERVICE_PORT=4003
NOTIFICATION_SERVICE_PORT=4004
VACCINATION_SERVICE_PORT=4005
JWT_SECRET=your-jwt-secret-key
JWT_EXPIRY=7d

# ── Python AI Service ─────────────────────────
AI_SERVICE_PORT=8001
AI_SERVICE_URL=http://localhost:8001

# ── Python Agent Service ──────────────────────
AGENT_SERVICE_PORT=8002
AGENT_SERVICE_URL=http://localhost:8002

# ── Vertex AI ─────────────────────────────────
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_MODEL_ENDPOINT=your-vertex-endpoint-id

# ── LangChain / LangSmith ─────────────────────
LANGCHAIN_API_KEY=your-langchain-api-key
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=companion-disease-risk-ai
LANGCHAIN_TRACING_V2=true

# ── Neo4j Ontology ────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password
NEO4J_DATABASE=companion_ontology

# ── Google Maps ───────────────────────────────
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ── Firebase Cloud Messaging ──────────────────
FCM_SERVER_KEY=your-fcm-server-key

# ── Frontend (Vite) ───────────────────────────
VITE_API_GATEWAY_URL=http://localhost:4000
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
